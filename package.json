{
  "name": "rental-app",
  "version": "2.3.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev src/app.ts",
    "build": "tsc",
    "build:all": "npm run build && npm --prefix frontend run build && npm --prefix institution-frontend run build",
    "start:prod": "node dist/app.js",
    "preflight:production": "NODE_ENV=production ts-node scripts/production_preflight.ts",
    "test": "jest",
    "test:backend": "jest --config jest.config.js",
    "test:frontend": "npm --prefix frontend test",
    "test:all": "npm run test:backend -- --runInBand --forceExit && npm run test:frontend && npm --prefix institution-frontend run build",
    "dev:all": "concurrently -k -n back,front,institution \"npm run dev\" \"npm --prefix frontend start\" \"npm --prefix institution-frontend run dev\"",
    "dev:institution": "npm --prefix institution-frontend run dev",
    "build:institution": "npm --prefix institution-frontend run build",
    "test:rbac": "jest --runInBand src/__tests__/rbac.test.ts",
    "test:unit": "jest tests/unit",
    "test:e2e": "jest --config jest.config.e2e.js --runInBand",
    "seed": "ts-node src/seed.ts",
    "seed:services": "ts-node scripts/seed_services.ts",
    "seed:tenantpro-demo": "ts-node scripts/seed_tenantpro_demo.ts",
    "seed:tensioned-areas": "ts-node scripts/seed_tensioned_areas.ts",
    "import:tensioned-geojson": "ts-node scripts/import_tensioned_geojson.ts",
    "seed:rental-public-demo": "ts-node scripts/seed_rental_public_demo.ts",
    "migrate:lead-conversation-stage": "ts-node scripts/migrate_lead_conversation_stage.ts",
    "system-events:cleanup": "ts-node scripts/system_events_cleanup.ts",
    "partner-earnings:retry": "ts-node scripts/retry_partner_earnings.ts",
    "test:policies": "jest --runInBand --testPathPattern=\"tests/(policies|contracts|escrow)/.*policy.*\\.test\\.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@google/generative-ai": "^0.24.1",
    "@types/archiver": "^6.0.4",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.0.3",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "file-type": "^21.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "mongoose": "^7.8.9",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.17.1",
    "stripe": "^12.11.0",
    "twilio": "^5.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/helmet": "^0.0.48",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.2.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.2",
    "@types/supertest": "^2.0.12",
    "baseline-browser-mapping": "^2.9.8",
    "concurrently": "^10.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "form-data": "4.0.6"
  }
}
